<Window x:Class="File_Wizard.UI.Wpf.SftpLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login SFTP"
        Width="420"
        Height="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF5F8FC"
        FontFamily="Segoe UI">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Acceso SFTP"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="#131C2E" />

        <TextBlock Grid.Row="1"
                   Margin="0,6,0,16"
                   Text="Ingresa las credenciales antes de abrir File Wizard"
                   Foreground="#606C81"
                   FontSize="10.5" />

        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="30" />
                <RowDefinition Height="30" />
                <RowDefinition Height="30" />
                <RowDefinition Height="34" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="Host" VerticalAlignment="Center" />
            <TextBlock Grid.Row="1" Text="Puerto" VerticalAlignment="Center" />
            <TextBlock Grid.Row="2" Text="Usuario" VerticalAlignment="Center" />
            <TextBlock Grid.Row="3" Text="Contraseña" VerticalAlignment="Center" />
            <TextBlock Grid.Row="4" Text="Entorno" VerticalAlignment="Center" />

            <TextBox x:Name="HostTextBox"
                     Grid.Column="1"
                     VerticalContentAlignment="Center" />
            <TextBox x:Name="PortTextBox"
                     Grid.Row="1"
                     Grid.Column="1"
                     VerticalContentAlignment="Center" />
            <TextBox x:Name="UsernameTextBox"
                     Grid.Row="2"
                     Grid.Column="1"
                     VerticalContentAlignment="Center" />
            <PasswordBox x:Name="PasswordBox"
                         Grid.Row="3"
                         Grid.Column="1"
                     />
            <ComboBox x:Name="EnvironmentComboBox"
                      Grid.Row="4"
                      Grid.Column="1"
                                            SelectedIndex="0"
                                            SelectionChanged="EnvironmentComboBox_SelectionChanged">
                <ComboBoxItem Content="DESA" />
                <ComboBoxItem Content="TEST" />
                <ComboBoxItem Content="QA" />
            </ComboBox>

            <TextBlock x:Name="EnvironmentStatusTextBlock"
                       Grid.Row="5"
                       Grid.Column="1"
                       Margin="0,6,0,0"
                       TextWrapping="Wrap"
                       FontSize="10.5"
                       Foreground="#991B1B"
                       Text="" />
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="92"
                    Height="30"
                    Margin="0,0,10,0"
                    Background="#1F6FEB"
                    Foreground="White"
                    BorderThickness="0"
                    Content="Entrar"
                    IsDefault="True"
                    Click="LoginButton_Click" />
            <Button Width="82"
                    Height="30"
                    Content="Cancelar"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>