<Window x:Class="File_Wizard.UI.Wpf.DesaTestUploadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DESA-TEST Uploader"
        Width="980"
        Height="760"
        WindowStartupLocation="CenterScreen"
        Background="#FFF5F7FC"
        FontFamily="Segoe UI"
        Closing="Window_Closing">
    <Grid Margin="0,0,0,2">
        <Grid.RowDefinitions>
            <RowDefinition Height="151" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="#0F172A" Grid.Row="0">
            <Grid Margin="35,22,35,22">
                <TextBlock Text="DESA-TEST Uploader"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="White"
                           VerticalAlignment="Top" />
                <TextBlock Text="Sube y publica componentes del entorno DESA-TEST"
                           Margin="0,56,0,0"
                           FontSize="14"
                           Foreground="#BFCDE4"
                           VerticalAlignment="Top" />
                <Border HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Width="181"
                        Height="80"
                        Background="#1E293B"
                        CornerRadius="2">
                    <Image Source="pack://application:,,,/src/assets/NUEK-LOGO-BLANCO.png"
                           Stretch="Uniform"
                           Margin="10,8" />
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,24">
            <Grid Margin="21,25,21,25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="25" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="25" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="25" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Background="White" Padding="21" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="Conexión"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="#334155" />
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,12">
                            <TextBlock Width="135"
                                       Height="34"
                                       Margin="0,0,12,0"
                                       Background="#1F6FEB"
                                       Foreground="White"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center"
                                       Padding="0,7,0,0"
                                       Text="Sesión iniciada" />
                            <Button x:Name="ClearCacheButton"
                                    Width="160"
                                    Height="34"
                                    Margin="0,0,12,0"
                                    Content="Limpiar caché"
                                    Click="ClearCacheButton_Click" />
                            <TextBlock x:Name="ConnectionStatusText"
                                       Width="120"
                                       Height="34"
                                       Background="Tomato"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center"
                                       Padding="0,7,0,0"
                                       Text="DESCONECTADO" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Background="White" Padding="21" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="Subida por selección"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"
                                   Foreground="#0F172A" />

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Directorio local" FontWeight="SemiBold" />
                                <DockPanel Margin="0,8,0,8">
                                    <Button x:Name="BrowseButton"
                                            Width="120"
                                            Height="30"
                                            Content="Explorar"
                                            DockPanel.Dock="Right"
                                            Margin="8,0,0,0"
                                            Click="BrowseButton_Click" />
                                    <TextBox x:Name="LocalDirectoryTextBox"
                                             Height="30"
                                             Text="C:\"
                                             VerticalContentAlignment="Center"
                                             IsReadOnly="True" />
                                </DockPanel>

                                <TextBlock Text="Archivos seleccionados" FontWeight="SemiBold" />
                                <TextBox x:Name="SelectedFilesTextBox"
                                         Height="120"
                                         Margin="0,8,0,0"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         TextWrapping="Wrap"
                                         IsReadOnly="True"
                                         Text="Aún no hay archivos seleccionados" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Destino" FontWeight="SemiBold" />
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,12">
                                    <RadioButton x:Name="DesaRadioButton"
                                                 Content="SATCDPDESA"
                                                 IsChecked="True"
                                                 Margin="0,0,16,0"
                                                 Foreground="#374151" />
                                    <RadioButton x:Name="TestRadioButton"
                                                 Content="SATCDPTEST"
                                                 Foreground="#374151" />
                                </StackPanel>

                                  <CheckBox x:Name="DatSecRoutingCheckBox"
                                        Margin="0,0,0,10"
                                        Content="Modo DAT/SEC (en vez de DAT/CPY)"
                                        Foreground="#334155"
                                        ToolTip="Si está activo, los componentes candidatos se enviarán a /dat o /sec." />

                                <Button x:Name="UploadFileButton"
                                        Height="34"
                                        Margin="0,0,0,8"
                                        Content="Subir archivos"
                                        Background="#10B981"
                                        Foreground="White"
                                        FontWeight="SemiBold"
                                        Click="UploadFileButton_Click" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="4" Background="White" Padding="21" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="Decisión por archivo"
                                   FontWeight="Bold"
                                   Foreground="#0F172A" />
                        <TextBlock Margin="0,10,0,10"
                                   Foreground="#64748B"
                                   Text="Define el destino para componentes candidatos. Esta selección se reutiliza durante la carga en lote." />

                        <DataGrid x:Name="DestinationDecisionsGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  Height="170"
                                  GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Archivo"
                                                    Width="*"
                                                    Binding="{Binding FileName}" />
                                <DataGridTemplateColumn Header="Destino" Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding AvailableTargets}"
                                                      SelectedItem="{Binding SelectedTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Detección"
                                                    Width="220"
                                                    Binding="{Binding DetectionStatus}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="6" Background="White" Padding="21" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="Resumen"
                                   FontWeight="Bold"
                                   Foreground="#0F172A" />
                        <TextBlock Margin="0,12,0,0"
                                   Foreground="#64748B"
                                   Text="Solo está habilitada la subida por selección múltiple desde el explorador." />
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>