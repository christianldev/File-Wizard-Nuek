<Window x:Class="File_Wizard.UI.Wpf.DesaTestDownloadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DESA-TEST Downloader"
        Width="1168"
        Height="1023"
        WindowStartupLocation="CenterScreen"
        Background="#FFF5F7FC"
        FontFamily="Segoe UI"
        Closing="Window_Closing">
    <Grid Margin="0,0,0,2">
        <Grid.RowDefinitions>
            <RowDefinition Height="151" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="#0F172A" Grid.Row="0">
            <Grid Margin="35,22,35,22">
                <TextBlock Text="DESA-TEST Downloader"
                           FontSize="23.25"
                           FontWeight="SemiBold"
                           Foreground="White"
                           VerticalAlignment="Top" />
                <TextBlock Text="Busca, descarga y administra componentes del entorno DESA-TEST"
                           Margin="0,56,0,0"
                           FontSize="10"
                           Foreground="#BFCDE4"
                           VerticalAlignment="Top" />
                <Border HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Width="181"
                        Height="49"
                        Background="#1E293B"
                        CornerRadius="2">
                    <TextBlock Text="DESA-TEST"
                               Foreground="#93C5FD"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,136">
            <Grid Margin="21,25,21,25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="25" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="25" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Background="White" Padding="21" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="Conexión"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="#334155" />
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,12">
                            <Button x:Name="ConnectButton"
                                    Width="135"
                                    Height="34"
                                    Margin="0,0,12,0"
                                    Content="Conectar"
                                    Click="ConnectButton_Click" />
                            
                            <Button x:Name="ClearCacheButton"
                                    Width="160"
                                    Height="34"
                                    Margin="0,0,12,0"
                                    Content="Limpiar caché"
                                    Click="ClearCacheButton_Click" />
                            <TextBlock x:Name="ConnectionStatusText"
           Width="120"
           Height="34"
           Background="Tomato"
           Foreground="White"
           FontWeight="Bold"
           TextAlignment="Center"
           VerticalAlignment="Center"
           Padding="0,7,0,0"
           Text="DESCONECTADO" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Background="White" Padding="21" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="Descarga por listado"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="#0F172A" />
                        <TextBlock Text="Escribe una línea por archivo o patrón (* o ?)."
                                   Margin="0,6,0,12"
                                   Foreground="#64748B" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Ambiente:" VerticalAlignment="Center" Margin="0,0,12,0" />
                            <RadioButton x:Name="DesaRadioButton" Content="DESA" IsChecked="True" Margin="0,0,12,0" />
                            <RadioButton x:Name="TestRadioButton" Content="TEST" Margin="0,0,12,0" />
                            <CheckBox x:Name="PrefixCheckBox" Content="PREFIJO?" IsChecked="True" VerticalAlignment="Center" />
                        </StackPanel>
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Directorio local" FontWeight="SemiBold" />
                                <DockPanel Margin="0,8,0,8">
                                    <Button x:Name="BrowseButton"
                                            Width="120"
                                            Height="30"
                                            Content="Explorar"
                                            DockPanel.Dock="Right"
                                            Margin="8,0,0,0"
                                            Click="BrowseButton_Click" />
                                    <TextBox x:Name="LocalDirectoryTextBox"
                                             Height="30"
                                             Text="C:\"
                                             VerticalContentAlignment="Center" />
                                </DockPanel>

                                <TextBlock Text="Listado de archivos" FontWeight="SemiBold" />
                                <TextBox x:Name="FilesTextBox"
                                         Height="120"
                                         Margin="0,8,0,8"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         TextWrapping="Wrap" />

                                <TextBlock Text="Descarga manual" FontWeight="SemiBold" />
                                <TextBlock Text="(escribir ruta completa y nombre del archivo)"
                                           Margin="0,4,0,8"
                                           Foreground="#64748B" />
                                <DockPanel>
                                    <Button x:Name="ManualDownloadButton"
                                            Width="120"
                                            Height="30"
                                            Content="Descargar"
                                            DockPanel.Dock="Right"
                                            Margin="8,0,0,0"
                                            Click="ManualDownloadButton_Click" />
                                    <TextBox x:Name="ManualPathTextBox"
                                             Height="30"
                                             Text="/sat/cdp/desa/dat/MPJ01010.FLOG0064"
                                             KeyDown="ManualPathTextBox_KeyDown"
                                             VerticalContentAlignment="Center" />
                                </DockPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Progreso" FontWeight="SemiBold" />
                                <ProgressBar x:Name="DownloadProgressBar"
                                             Height="20"
                                             Margin="0,8,0,8"
                                             Visibility="Collapsed"
                                             Minimum="0"
                                             Maximum="100" />
                                <TextBlock x:Name="CurrentFileTextBlock"
                                           Margin="0,0,0,12"
                                           Foreground="#334155" />
                                <Button x:Name="DownloadButton"
                                        Height="34"
                                        Margin="0,0,0,8"
                                        Content="Descargar listado"
                                        Click="DownloadButton_Click" />
                                <Button x:Name="CancelButton"
                                        Height="34"
                                        Margin="0,0,0,8"
                                        Content="Cancelar"
                                        Click="CancelButton_Click" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="4" Background="White" Padding="21" CornerRadius="4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Estado" FontWeight="Bold" Foreground="#0F172A" />
                            <TextBlock x:Name="StatusTextBlock"
                                       Margin="0,12,0,8"
                                       Text="CONECTADO / DESCONECTADO"
                                       Foreground="#64748B" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Resumen" FontWeight="Bold" Foreground="#0F172A" />
                            <TextBlock x:Name="ResultTextBlock"
                                       Margin="0,12,0,0"
                                       Text="" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>