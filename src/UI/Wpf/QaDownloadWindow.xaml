<Window x:Class="File_Wizard.UI.Wpf.QaDownloadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QASSUR Downloader"
        Width="700"
        Height="540"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF5F8FC"
        FontFamily="Segoe UI"
        Closing="Window_Closing">
    <Window.Resources>
        <!-- Estilo básico sin bordes redondeados (CornerRadius no lo soporta el Button nativo en algunas versiones) -->
        <Style TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="130" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Directorio LOCAL:" FontSize="14" FontWeight="SemiBold" Foreground="#131C2E" VerticalAlignment="Center" />
        <Button Grid.Row="0" Grid.Column="2" x:Name="BrowseButton" Width="96" Height="28" Content="..." Click="BrowseButton_Click" Background="#E1E5ED" />
        <TextBox Grid.Row="0" Grid.Column="4" x:Name="LocalDirectoryTextBox" Height="66" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="White" BorderBrush="#D1D5DB" />
        <Border Grid.Row="2" Grid.Column="2" Margin="3,20,10,52" Width="117" Height="28" Background="#1F6FEB" VerticalAlignment="Center">
            <TextBlock Text="Sesión iniciada" Foreground="White" TextAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" />
        </Border>
        <Border Grid.Row="1" Grid.Column="4" Margin="0,16,0,0" Height="24" Width="120" Background="#FF6B6B" CornerRadius="4" HorizontalAlignment="Left" VerticalAlignment="Center">
            <TextBlock x:Name="ConnectionStatusText" Text="DESCONECTADO" Foreground="White" TextAlignment="Center" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="11" />
        </Border>

        <TextBlock Grid.Row="2" Margin="10,17,98,58" Text="Entorno:" FontSize="14" FontWeight="SemiBold" Foreground="#131C2E" />
        <StackPanel Grid.Row="2" Grid.Column="4" Margin="0,20,0,0" Orientation="Vertical">
            <RadioButton x:Name="Environment1RadioButton" Content="SATQANEXC (CERTIF)" IsChecked="True" Foreground="#374151" Margin="0,0,0,6" />
            <RadioButton x:Name="Environment2RadioButton" Content="SATQANEXUS (COMUNI)" Foreground="#374151" Margin="0,0,0,6" />
            <RadioButton x:Name="Environment3RadioButton" Content="SATBCNXQA (BCHILE)" Foreground="#374151" Margin="0,0,0,6" RenderTransformOrigin="0.383,0.73" />
            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                <RadioButton x:Name="OtherEnvironmentRadioButton" Content="OTRO (ESPECIFICAR)" Checked="OtherEnvironmentRadioButton_Checked" Unchecked="OtherEnvironmentRadioButton_Unchecked" Foreground="#374151" VerticalAlignment="Center" />
                <TextBox x:Name="OtherEnvironmentTextBox" Width="160" Height="24" Margin="10,0,0,0" Visibility="Collapsed" Text="satitanxqa" VerticalContentAlignment="Center" BorderBrush="#D1D5DB" />
            </StackPanel>
        </StackPanel>

        <Button Grid.Row="4" x:Name="DownloadListButton" Margin="0,22,166,0" Width="124" Height="40" Content="DESCARGA MASIVA" Click="DownloadListButton_Click" Background="#10B981" Foreground="White" FontWeight="SemiBold" Cursor="Hand" VerticalAlignment="Top" Grid.Column="4" />
        <Button Grid.Row="4" x:Name="CancelButton" Margin="0,67,166,0" Width="124" Height="30" Content="CANCELAR" Background="#FF6B6B" Foreground="White" Click="CancelButton_Click" Cursor="Hand" VerticalAlignment="Top" Grid.Column="4"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,24,0,0" Text="Lista de archivos a buscar:" FontSize="14" FontWeight="SemiBold" Foreground="#131C2E" />
        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,0,4" Text="(una línea por archivo o patrón)" Foreground="#606C81" FontSize="11" />
        <TextBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" x:Name="FilesTextBox" Height="90" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Background="White" BorderBrush="#D1D5DB" Padding="4" />

        <Button Grid.Row="4" Grid.Column="4" x:Name="ClearCacheButton" Width="120" Height="32" Content="LIMPIAR CACHÉ" Click="ClearCacheButton_Click" Background="#6B7280" Foreground="White" Cursor="Hand" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="145,50,0,0" />

        <ProgressBar Grid.Row="4" Grid.Column="4" x:Name="DownloadProgressBar" Height="14" Visibility="Collapsed" Minimum="0" Maximum="100" Margin="0,32,0,0" VerticalAlignment="Top" Foreground="#1F6FEB" Background="#E1E5ED" BorderThickness="0" />
        <TextBlock Grid.Row="4" Grid.Column="4" x:Name="CurrentItemTextBlock" Margin="0,52,0,0" Foreground="#131C2E" FontWeight="SemiBold" FontSize="11" VerticalAlignment="Top" TextWrapping="Wrap" />
        <TextBlock Grid.Row="4" Grid.Column="4" x:Name="ResultTextBlock" Margin="0,82,0,0" Foreground="#10B981" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Top" TextWrapping="Wrap" />

        <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,20,0,0" Text="Descarga manual eliminada" FontSize="14" FontWeight="SemiBold" Foreground="#131C2E" />
        <TextBlock Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,40,0,0" Text="(ahora solo se usa descarga por listado)" FontSize="11" Foreground="#606C81" />

        <TextBlock Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="4" Margin="0,8,0,0" x:Name="StatusDetailsTextBlock" Foreground="#131C2E" FontSize="11" />
    </Grid>
</Window>